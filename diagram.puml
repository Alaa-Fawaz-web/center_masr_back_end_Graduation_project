@startuml
!theme spacelab

package "Auth & User" {
  class User {
    id
    name
    email
    role
  }

  class RefreshToken
  class Follower
  class Review
}

package "Roles" {
  class Teacher
  class Student
  class Center
}

package "Academic" {
  class Course
  class Lesson
  class Exam
  class Homework
  class Note
  class BookedLesson
}

package "Scheduling" {
  class WeeklySchedule
  class TeacherDay
  class BookedWeekly
}

package "Social" {
  class Post
  class Comment
  class Like
}

package "Chat" {
  class Conversation
  class Message
  class UserConversation
}

package "Notification" {
  class Notification
}

